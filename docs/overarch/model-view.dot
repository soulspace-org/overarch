digraph "Overarch Model" {
  labelloc= "t"
  label="Overarch Model"

  layout=dot
overarch_concepts__protocol [shape=box style=filled fillcolor="#dddddd" label=<<B>Protocol</B><BR/><FONT POINT-SIZE="10"><I>A contract that defines a set of<BR/>operations that a type must implement. </I></FONT>>]
overarch_data_model__control [shape=box  label=<<B>control</B><BR/><FONT POINT-SIZE="10"><I>A control in the process model </I></FONT>>]
overarch_data_model__element_desc_field [  label=<<B>desc</B><BR/><FONT POINT-SIZE="10"><I>(Short) description of the element.<BR/>Could be rendered in diagrams. </I></FONT>>]
overarch_data_model__aggregation [shape=box  label=<<B>aggregation</B><BR/><FONT POINT-SIZE="10"><I>A aggregation relationship between two<BR/>classes in the code model. </I></FONT>>]
overarch_architecture_decision__data_representation [  label=<<B>Internal Data Representation</B><BR/><FONT POINT-SIZE="10"><I>Model elements are stored in a graph of<BR/>nodes and relations </I></FONT>>]
overarch_data_model__permission [shape=box  label=<<B>permission</B><BR/><FONT POINT-SIZE="10"><I>A permission, entitlement or access<BR/>right for some action e.g. in a system. </I></FONT>>]
overarch_concepts__permission [shape=box style=filled fillcolor="#dddddd" label=<<B>Permission</B><BR/><FONT POINT-SIZE="10"><I>A permission, e.g. an access right. </I></FONT>>]
overarch_data_model__contained_in [shape=box  label=<<B>contained-in</B><BR/><FONT POINT-SIZE="10"><I>A composition relation from child to<BR/>parent. </I></FONT>>]
overarch_architecture__editor [shape=box style=filled fillcolor="#999999" label=<<B>Editor/IDE</B><BR/><FONT POINT-SIZE="10"><I>Tool for describing the architecture<BR/>model and the views. </I></FONT>>]
overarch_concepts__capability [shape=box style=filled fillcolor="#dddddd" label=<<B>Capability</B><BR/><FONT POINT-SIZE="10"><I>A capability in the process model, e.g.<BR/>a business capability or a technical<BR/>capability. </I></FONT>>]
overarch_data_model__method [shape=box  label=<<B>method</B><BR/><FONT POINT-SIZE="10"><I>A method in a code model element. </I></FONT>>]
overarch_concepts__actor [shape=box style=filled fillcolor="#dddddd" label=<<B>Actor</B><BR/><FONT POINT-SIZE="10"><I>An actor (role) in a use case model. </I></FONT>>]
overarch_architecture_goal__knowledge_models [  label=<<B>Open Architecture Knowledge Platform</B><BR/><FONT POINT-SIZE="10"><I>An Overarch model shall capture<BR/>architectural knowledge on different<BR/>levels (e.g. enterprise, business,<BR/>system, code, deployment). </I></FONT>>]
overarch_data_model__type_hierarchy_relation [shape=box  label=<<B>type-hierarchy-relation</B><BR/><FONT POINT-SIZE="10"><I>A relation that establishes a type<BR/>hierarchy. </I></FONT>>]
overarch_use_case__define_views [shape=ellipse style=filled fillcolor=yellow label=<<B>define views</B><BR/><FONT POINT-SIZE="10"><I>Textually define views of the system in<BR/>the Overarch view model. </I></FONT>>]
overarch_concepts__history_state [shape=box style=filled fillcolor="#dddddd" label=<<B>History State</B><BR/><FONT POINT-SIZE="10"><I>Remembers the last active substate </I></FONT>>]
overarch_data_model__enum_value [shape=box  label=<<B>enum-value</B><BR/><FONT POINT-SIZE="10"><I>A value of an enumeration in the code<BR/>model. </I></FONT>>]
overarch_concepts__stereotype [shape=box style=filled fillcolor="#dddddd" label=<<B>Stereotype</B><BR/><FONT POINT-SIZE="10"><I>A stereotype in the code model. </I></FONT>>]
overarch_concepts__annotation [shape=box style=filled fillcolor="#dddddd" label=<<B>Annotation</B><BR/><FONT POINT-SIZE="10"><I>An annotation in the code model. </I></FONT>>]
overarch_data_model__regulation_for [shape=box  label=<<B>regulation-for</B><BR/><FONT POINT-SIZE="10"><I>A relation between regulation and other<BR/>elements. </I></FONT>>]
overarch_data_model__field [shape=box  label=<<B>field</B><BR/><FONT POINT-SIZE="10"><I>A field in a code model element. </I></FONT>>]
overarch_concepts__person [shape=box style=filled fillcolor="#dddddd" label=<<B>Person</B><BR/><FONT POINT-SIZE="10"><I>A human actor or role (deprecated, use<BR/>role). </I></FONT>>]
overarch_data_model__enterprise_boundary [shape=box  label=<<B>enterprise-boundary</B><BR/><FONT POINT-SIZE="10"><I>A boundary of an enterprise or a<BR/>company. </I></FONT>>]
overarch_data_model__technical_architecture_model_node [shape=box  label=<<B>technical-architecture-model-node</B><BR/><FONT POINT-SIZE="10"><I>A technical node in the architecture<BR/>model. </I></FONT>>]
overarch_data_model__rendering_spec_layout_field [  label=<<B>layout</B><BR/><FONT POINT-SIZE="10"><I>A directive for the renderer to change<BR/>the rendering (if supported by the<BR/>renderer). </I></FONT>>]
overarch_concepts__schema [shape=box style=filled fillcolor="#dddddd" label=<<B>Schema</B><BR/><FONT POINT-SIZE="10"><I>Describes the structure of data, e.g. a<BR/>database schema or a JSON schema. </I></FONT>>]
overarch_data_model__publish [shape=box  label=<<B>publish</B><BR/><FONT POINT-SIZE="10"><I>Publishing of asynchronous events<BR/>between two elements of the architecture<BR/>(receiver should be a broker or topic). </I></FONT>>]
overarch_data_model__aggregate [shape=box  label=<<B>aggregate</B><BR/><FONT POINT-SIZE="10"><I>A cluster of domain objects that can be<BR/>treated as a single unit for consistency<BR/>and invariants. Part of the solution<BR/>space. </I></FONT>>]
overarch_architecture_decision__implementation_language [  label=<<B>Implementation Language</B><BR/><FONT POINT-SIZE="10"><I>Clojure is used as sole implementation<BR/>language </I></FONT>>]
overarch_architecture_constraint__platform_independent [  label=<<B>Platform Independent</B><BR/><FONT POINT-SIZE="10"><I>The Overarch system shall be platform<BR/>independent. </I></FONT>>]
overarch_data_model__domain_model_relation [shape=box  label=<<B>domain-model-relation</B><BR/><FONT POINT-SIZE="10"><I>A relation in the domain model. </I></FONT>>]
overarch_use_case__generate_artifacts [shape=ellipse style=filled fillcolor=yellow label=<<B>generate artifacts </B><BR/><FONT POINT-SIZE="10"><I>Generate artifacts with templates from<BR/>model selections. </I></FONT>>]
overarch_concepts__container_instance [shape=box style=filled fillcolor="#dddddd" label=<<B>Container Instance</B><BR/><FONT POINT-SIZE="10"><I>Deployed instance of a container in the<BR/>deployment model </I></FONT>>]
overarch_concepts__concept [shape=box style=filled fillcolor="#dddddd" label=<<B>Concept</B><BR/><FONT POINT-SIZE="10"><I>Describes a thing or an idea. </I></FONT>>]
overarch_data_model__inheritance [shape=box  label=<<B>inheritance</B><BR/><FONT POINT-SIZE="10"><I>An inheritance relationship between two<BR/>classes in the code model. </I></FONT>>]
overarch_data_model__concept_model_element [shape=box  label=<<B>concept-model-element</B><BR/><FONT POINT-SIZE="10"><I>An element in the concept model. </I></FONT>>]
overarch_data_model__function [shape=box  label=<<B>function</B><BR/><FONT POINT-SIZE="10"><I>A function in the code model. </I></FONT>>]
overarch_architecture_goal__customizable_model_scopes [  label=<<B>Customizable Scopes</B><BR/><FONT POINT-SIZE="10"><I>The scope of the viewpoints on the model<BR/>is selectable. </I></FONT>>]
overarch_data_model__parameter [shape=box  label=<<B>parameter</B><BR/><FONT POINT-SIZE="10"><I>A parameter in a code model method or<BR/>function. </I></FONT>>]
overarch_data_model__organization_model_relation [shape=box  label=<<B>organization-model-relation</B><BR/><FONT POINT-SIZE="10"><I>A relation in the organization model </I></FONT>>]
overarch_data_model__state_machine_view [shape=box  label=<<B>state-machine-view</B><BR/><FONT POINT-SIZE="10"><I>The state machine view is a behavioural<BR/>design view. It shows states and<BR/>transitions of a state machine. </I></FONT>>]
overarch_architecture__overarch_cli [shape=box style=filled fillcolor="#438dd5" label=<<B>Overarch CLI</B><BR/><FONT POINT-SIZE="10"><I>CLI tool for the generation of value<BR/>from the knowledge. </I></FONT>>]
overarch_concepts__function [shape=box style=filled fillcolor="#dddddd" label=<<B>Function</B><BR/><FONT POINT-SIZE="10"><I>A function in the code model. </I></FONT>>]
overarch_data_model__artifact [shape=box  label=<<B>artifact</B><BR/><FONT POINT-SIZE="10"><I>An artifact in the process model </I></FONT>>]
overarch_data_model__extends [shape=box  label=<<B>extends</B><BR/><FONT POINT-SIZE="10"><I>An extends relationship between two use<BR/>cases. </I></FONT>>]
overarch_concepts__container [shape=box style=filled fillcolor="#dddddd" label=<<B>Container</B><BR/><FONT POINT-SIZE="10"><I>a deployed process in the architecture<BR/>(e.g. a service or an application) </I></FONT>>]
overarch_concepts__state [shape=box style=filled fillcolor="#dddddd" label=<<B>State</B><BR/><FONT POINT-SIZE="10"><I>A state in a state machine </I></FONT>>]
overarch_data_model__history_state [shape=box  label=<<B>history-state</B><BR/><FONT POINT-SIZE="10"><I>A state with history. </I></FONT>>]
overarch_data_model__scoped_node [shape=box  label=<<B>scoped-node</B><BR/><FONT POINT-SIZE="10"><I>A node which may have a scope field. </I></FONT>>]
overarch_data_model__model_element_tags_field [  label=<<B>tags</B><BR/><FONT POINT-SIZE="10"><I>Set of string tags associated with the<BR/>element. </I></FONT>>]
overarch_data_model__association [shape=box  label=<<B>association</B><BR/><FONT POINT-SIZE="10"><I>A association relationship between two<BR/>classes in the code model. </I></FONT>>]
overarch_data_model__test_for [shape=box  label=<<B>test-for</B><BR/><FONT POINT-SIZE="10"><I>A relation between a test and other<BR/>elements. </I></FONT>>]
overarch_data_model__control_for [shape=box  label=<<B>control-for</B><BR/><FONT POINT-SIZE="10"><I>A relation between control and other<BR/>elements. </I></FONT>>]
overarch_data_model__rendering_spec_styles_field [  label=<<B>styles</B><BR/><FONT POINT-SIZE="10"><I>A directive for the renderer to style<BR/>elements (if supported by the renderer). </I></FONT>>]
overarch_data_model__deployment_model_relation [shape=box  label=<<B>deployment-model-relation</B><BR/><FONT POINT-SIZE="10"><I>A relation in the deployment model. </I></FONT>>]
overarch_data_model__information [shape=box  label=<<B>information</B><BR/><FONT POINT-SIZE="10"><I>An information in the process model </I></FONT>>]
overarch_data_model__link [shape=box  label=<<B>link</B><BR/><FONT POINT-SIZE="10"><I>A link between two nodes of the<BR/>deployment model. </I></FONT>>]
overarch_data_model__rendering_spec_theme_field [  label=<<B>theme</B><BR/><FONT POINT-SIZE="10"><I>A directive for the renderer use a them<BR/>to style elements (if supported by the<BR/>renderer). </I></FONT>>]
overarch_data_model__technical_architecture_model_node_subtype_field [  label=<<B>subtype</B><BR/><FONT POINT-SIZE="10"><I>Subtype of the element, one of :database<BR/>or :queue. </I></FONT>>]
overarch_architecture_decision__data_format [  label=<<B>Data Format for Models</B><BR/><FONT POINT-SIZE="10"><I>Extensible Data Notation (EDN) is used<BR/>as the data format for models and other<BR/>customization/configuration data </I></FONT>>]
overarch_data_model__concept_view [shape=box  label=<<B>concept-view</B><BR/><FONT POINT-SIZE="10"><I>The concept view is a graphical view. It<BR/>shows the concepts as a concept map with<BR/>the relations between the concepts. </I></FONT>>]
overarch_data_model__state_machine_model_element [shape=box  label=<<B>state-machine-model-element</B><BR/><FONT POINT-SIZE="10"><I>An element in a state machine model. </I></FONT>>]
overarch_util__functions [shape=box style=filled fillcolor="#85bbf0" label=<<B>util.functions</B><BR/><FONT POINT-SIZE="10"><I>Contains common functions. </I></FONT>>]
overarch_data_model__model_element [shape=box  label=<<B>model-element</B><BR/><FONT POINT-SIZE="10"><I>An element which describes the relation<BR/>of elements. </I></FONT>>]
overarch_data_model__include [shape=box  label=<<B>include</B><BR/><FONT POINT-SIZE="10"><I>A include relationship between two use<BR/>cases. </I></FONT>>]
overarch_data_model__namespace [shape=box  label=<<B>namespace</B><BR/><FONT POINT-SIZE="10"><I>A namespace in the code model.<BR/>Namespaces provide a hierarchical<BR/>structure for the organisation of the<BR/>elements of the class model. </I></FONT>>]
overarch_data_model__request [shape=box  label=<<B>request</B><BR/><FONT POINT-SIZE="10"><I>A synchronous request between two<BR/>elements of the architecture. </I></FONT>>]
overarch_data_model__use_case [shape=box  label=<<B>use-case</B><BR/><FONT POINT-SIZE="10"><I>A use case in the use case model. </I></FONT>>]
overarch_data_model__command [shape=box  label=<<B>command</B><BR/><FONT POINT-SIZE="10"><I>An instruction to perform a specific<BR/>action or operation within the domain. </I></FONT>>]
overarch_adapter_reader__model_reader [shape=box style=filled fillcolor="#85bbf0" label=<<B>adapter.reader.model-reader</B><BR/><FONT POINT-SIZE="10"><I>Contains the functions for reading and<BR/>building models and setting the<BR/>repository state. The multimethods<BR/>should be implemented by specific<BR/>readers. </I></FONT>>]
overarch_data_model__instance_of [shape=box  label=<<B>instance-of</B><BR/><FONT POINT-SIZE="10"><I>An element is an instance of another<BR/>element. </I></FONT>>]
overarch_data_model__architecture_model_node [shape=box  label=<<B>architecture-model-node</B><BR/><FONT POINT-SIZE="10"><I>A node in the architecture model. </I></FONT>>]
overarch_application__template [shape=box style=filled fillcolor="#85bbf0" label=<<B>application.template</B><BR/><FONT POINT-SIZE="10"><I>Contains the functions for template<BR/>based artifact generation and<BR/>multimethods to be implemented by the<BR/>concrete template engine adapter<BR/>implementations. </I></FONT>>]
overarch_data_model__rendering_spec_linetype_field [  label=<<B>linetype</B><BR/><FONT POINT-SIZE="10"><I>A directive for the renderer to change<BR/>the linetype for relations (if supported<BR/>by the renderer). </I></FONT>>]
overarch_concepts__fork [shape=box style=filled fillcolor="#dddddd" label=<<B>Fork</B><BR/><FONT POINT-SIZE="10"><I>Splits the flow into multiple concurrent<BR/>flows </I></FONT>>]
overarch_data_model__model [shape=box  label=<<B>model</B><BR/><FONT POINT-SIZE="10"><I>A representation of a domain that<BR/>captures the essential aspects. Part of<BR/>the solution space. </I></FONT>>]
overarch_concepts__organization [shape=box style=filled fillcolor="#dddddd" label=<<B>Organization</B><BR/><FONT POINT-SIZE="10"><I>An organization (e.g. a company) in the<BR/>organization model. </I></FONT>>]
overarch_data_model__ref [shape=box  label=<<B>ref</B><BR/><FONT POINT-SIZE="10"><I>A reference to an element. </I></FONT>>]
overarch_concepts__deep_history_state [shape=box style=filled fillcolor="#dddddd" label=<<B>Deep History State</B><BR/><FONT POINT-SIZE="10"><I>Remembers the last active substate in a<BR/>substate </I></FONT>>]
overarch_data_model__person [shape=box  label=<<B>person</B><BR/><FONT POINT-SIZE="10"><I>A human actor or role working with the<BR/>system under description. A person can<BR/>be used in the architecture model and<BR/>the use case model. </I></FONT>>]
overarch_architecture_goal__queryably_models [  label=<<B>Queryable Models</B><BR/><FONT POINT-SIZE="10"><I>Model can be queried to answer specific<BR/>questions or to select a specific subset<BR/>of the model. </I></FONT>>]
overarch_data_model__scoped_node_scope_field [  label=<<B>scope</B><BR/><FONT POINT-SIZE="10"><I>The scope of the element (:classifier or<BR/>:instance). Defaults to instance. </I></FONT>>]
overarch_concepts__entity [shape=box style=filled fillcolor="#dddddd" label=<<B>Entity</B><BR/><FONT POINT-SIZE="10"><I>An object that is defined by its<BR/>identity, rather than its attributes.<BR/>Part of the solution space. </I></FONT>>]
overarch_data_model__component [shape=box  label=<<B>component</B><BR/><FONT POINT-SIZE="10"><I>A compontent is a part of a container<BR/>and describes a (logical) building block<BR/>of a container (e.g. a module or a<BR/>layer). </I></FONT>>]
overarch_data_model__architecture_model_relation [shape=box  label=<<B>architecture-model-relation</B><BR/><FONT POINT-SIZE="10"><I>A relation in the architecture model. </I></FONT>>]
overarch_concepts__role [shape=box style=filled fillcolor="#dddddd" label=<<B>Role</B><BR/><FONT POINT-SIZE="10"><I>A role in the model, e.g. a person or a<BR/>system. </I></FONT>>]
overarch_data_model__package [shape=box  label=<<B>package</B><BR/><FONT POINT-SIZE="10"><I>A package in the code model. Packages<BR/>provide a hierarchical structure for the<BR/>organisation of the elements of the<BR/>class model. </I></FONT>>]
overarch_data_model__associative_relation_from_role_field [  label=<<B>from-role</B><BR/><FONT POINT-SIZE="10"><I>The role of the referring element. </I></FONT>>]
overarch_adapter_template__comb [shape=box style=filled fillcolor="#85bbf0" label=<<B>adapter.template.comb</B><BR/><FONT POINT-SIZE="10"><I>Contains the implementation of a<BR/>template engine for Comb templates. </I></FONT>>]
overarch_concepts__start_state [shape=box style=filled fillcolor="#dddddd" label=<<B>Start State</B><BR/><FONT POINT-SIZE="10"><I>The initial state of a state machine </I></FONT>>]
overarch_use_case__render_views [shape=ellipse style=filled fillcolor=yellow label=<<B>render views</B><BR/><FONT POINT-SIZE="10"><I>Render the views of the system. </I></FONT>>]
overarch_data_model__input_of [shape=box  label=<<B>input-of</B><BR/><FONT POINT-SIZE="10"><I>A relation between artifacts,<BR/>information or knowledge and processes. </I></FONT>>]
overarch_data_model__element_doc_field [  label=<<B>doc</B><BR/><FONT POINT-SIZE="10"><I>Documentation of the element. </I></FONT>>]
overarch_data_model__constraint [shape=box  label=<<B>constraint</B><BR/><FONT POINT-SIZE="10"><I>A constraint in the process model </I></FONT>>]
overarch_data_model__system_landscape_view [shape=box  label=<<B>system-landscape-view</B><BR/><FONT POINT-SIZE="10"><I>The system landscape view is a static<BR/>architectural view. It shows the broader<BR/>context of the system under description.<BR/>It contains the system under<BR/>descriptions, it&apos;s direct users and<BR/>interacting external systems and maybe<BR/>additional systems and users which play<BR/>a role in the broader context of the<BR/>system under description. </I></FONT>>]
overarch_data_model__visibility_node [shape=box  label=<<B>visibility-node</B><BR/><FONT POINT-SIZE="10"><I>A node which may have a visibility<BR/>field. </I></FONT>>]
overarch_data_model__send [shape=box  label=<<B>send</B><BR/><FONT POINT-SIZE="10"><I>An asynchronous message or command<BR/>between two elements of the architecture<BR/>(point-to-point). </I></FONT>>]
overarch_domain__model [shape=box style=filled fillcolor="#85bbf0" label=<<B>domain.model</B><BR/><FONT POINT-SIZE="10"><I>Contains the model specification and<BR/>functions. </I></FONT>>]
overarch_data_model__model_relation_from_field [  label=<<B>from</B><BR/><FONT POINT-SIZE="10"><I>The identifier of the model node<BR/>referring to another model node. </I></FONT>>]
overarch_data_model__component_view [shape=box  label=<<B>component-view</B><BR/><FONT POINT-SIZE="10"><I>The component view is a static<BR/>architectural view. It shows the<BR/>component structure of a container and<BR/>the interactions between these<BR/>components and with it&apos;s environment<BR/>consisting of users and external<BR/>systems. </I></FONT>>]
overarch_roles__modeller [shape=box style=filled fillcolor="#08427b" label=<<B>Modeller</B><BR/><FONT POINT-SIZE="10"><I>Models the architecture of a system and<BR/>specifies views of the model. </I></FONT>>]
overarch_architecture_goal__composeable_models [  label=<<B>Composeable Models</B><BR/><FONT POINT-SIZE="10"><I>Models from different sources can be<BR/>composed to form a larger model. </I></FONT>>]
overarch_data_model__associative_relation_qualifier_field [  label=<<B>qualifier</B><BR/><FONT POINT-SIZE="10"><I>The name of a field for associative<BR/>access. </I></FONT>>]
overarch_data_model__use_case_level_field [  label=<<B>level</B><BR/><FONT POINT-SIZE="10"><I>The level of the use case (:summary,<BR/>:user-goal, :subfunction). </I></FONT>>]
overarch_data_model__process_model_element [shape=box  label=<<B>process-model-element</B><BR/><FONT POINT-SIZE="10"><I>An element in the process model </I></FONT>>]
overarch_concepts__technical_architecture_node [shape=box style=filled fillcolor="#dddddd" label=<<B>Technical Architecture Node</B><BR/><FONT POINT-SIZE="10"><I>A technical node in the architecture<BR/>model </I></FONT>>]
overarch_data_model__granted_for [shape=box  label=<<B>granted-for</B><BR/><FONT POINT-SIZE="10"><I>A relationship between a permission and<BR/>a role. </I></FONT>>]
overarch_data_model__role_model_element_external_field [  label=<<B>external</B><BR/><FONT POINT-SIZE="10"><I>When true, the element plays a role in<BR/>the model but it is not in the scope of<BR/>the project. Defaults to false. </I></FONT>>]
overarch_data_model__optional_node [shape=box  label=<<B>optional-node</B><BR/><FONT POINT-SIZE="10"><I>A node which may have an optional field. </I></FONT>>]
overarch_concepts__domain [shape=box style=filled fillcolor="#dddddd" label=<<B>Domain</B><BR/><FONT POINT-SIZE="10"><I>A specific area of knowledge, activity<BR/>or subject matter. Part of the problem<BR/>space. </I></FONT>>]
overarch_data_model__implements [shape=box  label=<<B>implements</B><BR/><FONT POINT-SIZE="10"><I>A trace relation from an implementation<BR/>to its definition. </I></FONT>>]
overarch_data_model__deployed_to [shape=box  label=<<B>deployed-to</B><BR/><FONT POINT-SIZE="10"><I>A deployment relation between a<BR/>container or an artifact and a node in<BR/>the deployment model. The container or<BR/>artifact is deployed to the node. </I></FONT>>]
overarch_data_model__capability [shape=box  label=<<B>capability</B><BR/><FONT POINT-SIZE="10"><I>A capability in the process model </I></FONT>>]
overarch_data_model__technical_element [shape=box  label=<<B>technical-element</B><BR/><FONT POINT-SIZE="10"><I>An element which is implemented in the<BR/>given technologies. </I></FONT>>]
overarch_data_model__generalizes [shape=box  label=<<B>generalizes</B><BR/><FONT POINT-SIZE="10"><I>A generalizes relationship between two<BR/>use case elements. </I></FONT>>]
overarch_data_model__knowledge [shape=box  label=<<B>knowledge</B><BR/><FONT POINT-SIZE="10"><I>A process in the process model </I></FONT>>]
overarch_data_model__version [shape=box  label=<<B>version</B><BR/><FONT POINT-SIZE="10"><I>A version of an artifact in the process<BR/>model </I></FONT>>]
overarch_data_model__system_structure_view [shape=box  label=<<B>system-structure-view</B><BR/><FONT POINT-SIZE="10"><I>The system structure view is a graphical<BR/>view. It shows the hierarchy of the<BR/>system and its parts as an organigram. </I></FONT>>]
overarch_concepts__parameter [shape=box style=filled fillcolor="#dddddd" label=<<B>Parameter</B><BR/><FONT POINT-SIZE="10"><I>A parameter of a method or function in<BR/>the code model. </I></FONT>>]
overarch_data_model__deep_history_state [shape=box  label=<<B>deep-history-state</B><BR/><FONT POINT-SIZE="10"><I>A state with a deep history. </I></FONT>>]
overarch_data_model__org_unit [shape=box  label=<<B>org-unit</B><BR/><FONT POINT-SIZE="10"><I>An organizational unit (e.g. a<BR/>department) in the organization model. </I></FONT>>]
overarch_data_model__value_object [shape=box  label=<<B>value-object</B><BR/><FONT POINT-SIZE="10"><I>An object that is defined by its<BR/>attributes rather than its identity.<BR/>Part of the solution space. </I></FONT>>]
overarch_use_case__export_json [shape=ellipse style=filled fillcolor=yellow label=<<B>export JSON</B><BR/><FONT POINT-SIZE="10"><I>Export the model and views to JSON. </I></FONT>>]
overarch_data_model__response [shape=box  label=<<B>response</B><BR/><FONT POINT-SIZE="10"><I>A response to a synchronous request<BR/>between two elements of the<BR/>architecture. </I></FONT>>]
overarch_data_model__typed_node_type_field [  label=<<B>type</B><BR/><FONT POINT-SIZE="10"><I>The type of the element. </I></FONT>>]
overarch_data_model__entity [shape=box  label=<<B>entity</B><BR/><FONT POINT-SIZE="10"><I>An object that is defined by its<BR/>identity rather than its attributes.<BR/>Part of the solution space. </I></FONT>>]
overarch_data_model__system [shape=box  label=<<B>system</B><BR/><FONT POINT-SIZE="10"><I>A system relevant in the architecture. A<BR/>system can be an external system, which<BR/>is modelled as a black box or an<BR/>internal system, a system under<BR/>description, which is modelled as a<BR/>compound element with all the containers<BR/>of the system. A system can be used in<BR/>the architecture model, the deployment<BR/>model (external systems) and the use<BR/>case model (external systems). </I></FONT>>]
overarch_data_model__rendering_spec_selection_field [  label=<<B>selection</B><BR/><FONT POINT-SIZE="10"><I>A directive to select the elements for<BR/>the view by the critera. </I></FONT>>]
overarch_data_model__required_for [shape=box  label=<<B>required-for</B><BR/><FONT POINT-SIZE="10"><I>A relation between other nodes and<BR/>capabilities. </I></FONT>>]
overarch_data_model__artifact_of [shape=box  label=<<B>artifact-of</B><BR/><FONT POINT-SIZE="10"><I>A relation between artifacts and other<BR/>process or deployment model nodes. </I></FONT>>]
overarch_data_model__rendering_spec_include_field [  label=<<B>include</B><BR/><FONT POINT-SIZE="10"><I>A directive to include additional<BR/>elements in the view. </I></FONT>>]
overarch_data_model__organization_model_element [shape=box  label=<<B>organization-model-element</B><BR/><FONT POINT-SIZE="10"><I>An element in the organization model </I></FONT>>]
overarch_concepts__namespace [shape=box style=filled fillcolor="#dddddd" label=<<B>Namespace</B><BR/><FONT POINT-SIZE="10"><I>A namespace in the code model. </I></FONT>>]
overarch_data_model__container [shape=box  label=<<B>container</B><BR/><FONT POINT-SIZE="10"><I>A container is a part of a system and<BR/>describes a deployed process in the<BR/>architecture (e.g. a service or an<BR/>application). A container is a compound<BR/>element which contains the components of<BR/>the implementation. A container can be<BR/>used in the architecture model, the<BR/>deployment model and the use case model. </I></FONT>>]
overarch_concepts__command [shape=box style=filled fillcolor="#dddddd" label=<<B>Command</B><BR/><FONT POINT-SIZE="10"><I>An instruction to perform a specific<BR/>action or operation within the domain.<BR/>Part of the solution space. </I></FONT>>]
overarch_data_model__use_case_view [shape=box  label=<<B>use-case-view</B><BR/><FONT POINT-SIZE="10"><I>The use case view is a behavioural view<BR/>of the (functional) requirements. It<BR/>shows the actors of the system and the<BR/>use cases to provide an overview of the<BR/>functionality of the system under<BR/>description. </I></FONT>>]
overarch_concepts__value_object [shape=box style=filled fillcolor="#dddddd" label=<<B>Value Object</B><BR/><FONT POINT-SIZE="10"><I>An object that is defined by its<BR/>attributes, rather than its identity.<BR/>Part of the solution space. </I></FONT>>]
overarch_adapter_render__graphviz [shape=box style=filled fillcolor="#85bbf0" label=<<B>adapter.render.graphviz</B><BR/><FONT POINT-SIZE="10"><I>Contains the implementation of the<BR/>Graphviz rendering. </I></FONT>>]
overarch_data_model__choice_condition_field [  label=<<B>condition</B><BR/><FONT POINT-SIZE="10"><I>The condition of the choice state. </I></FONT>>]
overarch_concepts__choice [shape=box style=filled fillcolor="#dddddd" label=<<B>Choice</B><BR/><FONT POINT-SIZE="10"><I>Selects one of several alternative paths </I></FONT>>]
overarch_data_model__code_view [shape=box  label=<<B>code-view</B><BR/><FONT POINT-SIZE="10"><I>The code view is a static design view.<BR/>It shows the code structure of some<BR/>components of the system. </I></FONT>>]
overarch_concepts__domain_event [shape=box style=filled fillcolor="#dddddd" label=<<B>Domain Event</B><BR/><FONT POINT-SIZE="10"><I>An event that represents a significant<BR/>change in the state of the domain. Part<BR/>of the solution space. </I></FONT>>]
overarch_data_model__process_model_node [shape=box  label=<<B>process-model-node</B><BR/><FONT POINT-SIZE="10"><I>A node in the process model </I></FONT>>]
overarch_data_model__deployment_model_node [shape=box  label=<<B>deployment-model-node</B><BR/><FONT POINT-SIZE="10"><I>A node in the deployment model. </I></FONT>>]
overarch_use_case__query_model [shape=ellipse style=filled fillcolor=yellow label=<<B>query model</B><BR/><FONT POINT-SIZE="10"><I>Query the model with selection criteria. </I></FONT>>]
overarch_architecture_constraint__open_source [  label=<<B>Open Source</B><BR/><FONT POINT-SIZE="10"><I>The Overarch system shall be open<BR/>source. </I></FONT>>]
overarch_concepts__node [shape=box style=filled fillcolor="#dddddd" label=<<B>Node</B><BR/><FONT POINT-SIZE="10"><I>Part of the infrastructure in the<BR/>deployment model </I></FONT>>]
overarch_adapter_render__plantuml [shape=box style=filled fillcolor="#85bbf0" label=<<B>adapter.render.plantuml</B><BR/><FONT POINT-SIZE="10"><I>Contains the implementation of the<BR/>PlantUML rendering. </I></FONT>>]
overarch_architecture_requirement__namespaced_ids [  label=<<B>Namespaced IDs for elements</B><BR/><FONT POINT-SIZE="10"><I>For models to be composeable, the IDs<BR/>for elements of Overarch models must be<BR/>namespaced to avoid clashes across<BR/>different models. </I></FONT>>]
overarch_data_model__choice [shape=box  label=<<B>choice</B><BR/><FONT POINT-SIZE="10"><I>A choice of transitions in a state<BR/>machine. A choice has a single incoming<BR/>transition and multiple outgoing<BR/>transitions with the result of the<BR/>condition of the choice. </I></FONT>>]
overarch_data_model__model_relation_to_field [  label=<<B>to</B><BR/><FONT POINT-SIZE="10"><I>The identifier of the model node being<BR/>referred by another model node. </I></FONT>>]
overarch_architecture_goal__extensible_model_elements [  label=<<B>Extensible Models</B><BR/><FONT POINT-SIZE="10"><I>Model elements are open and can be<BR/>extended with additional information. </I></FONT>>]
overarch_concepts__method [shape=box style=filled fillcolor="#dddddd" label=<<B>Method</B><BR/><FONT POINT-SIZE="10"><I>A method of a class or interface in the<BR/>code model. </I></FONT>>]
overarch_concepts__bounded_context [shape=box style=filled fillcolor="#dddddd" label=<<B>Bounded Context</B><BR/><FONT POINT-SIZE="10"><I>A boundary within which a particular<BR/>domain model is valid and consistent.<BR/>Part of the solution space. </I></FONT>>]
overarch_data_model__dynamic_view [shape=box  label=<<B>dynamic-view</B><BR/><FONT POINT-SIZE="10"><I>The dynamic view is an architectural and<BR/>behavioural view. It shows the order of<BR/>some interactions between elements of<BR/>the architecture. </I></FONT>>]
overarch_data_model__node [shape=box  label=<<B>node</B><BR/><FONT POINT-SIZE="10"><I>An element of the deployment model of<BR/>the system under description. A node is<BR/>a compound element which contains other<BR/>nodes or containers referenced from the<BR/>architecture model. </I></FONT>>]
overarch_data_model__collaborates_with [shape=box  label=<<B>collaborates-with</B><BR/><FONT POINT-SIZE="10"><I>A relation between two organisational<BR/>model nodes. </I></FONT>>]
overarch_concepts__knowledge [shape=box style=filled fillcolor="#dddddd" label=<<B>Knowledge</B><BR/><FONT POINT-SIZE="10"><I>The understanding and skills acquired<BR/>through experience and education. </I></FONT>>]
overarch_application__render [shape=box style=filled fillcolor="#85bbf0" label=<<B>application.render</B><BR/><FONT POINT-SIZE="10"><I>Contains the render multimethods to be<BR/>implemented by the concrete render<BR/>adapter implementations. </I></FONT>>]
overarch_data_model__dataflow [shape=box  label=<<B>dataflow</B><BR/><FONT POINT-SIZE="10"><I>A flow of data between two elements of<BR/>the architecture. </I></FONT>>]
overarch_data_model__process_model_relation [shape=box  label=<<B>process-model-relation</B><BR/><FONT POINT-SIZE="10"><I>A relation in the process model </I></FONT>>]
overarch_data_model__goal_for [shape=box  label=<<B>goal-for</B><BR/><FONT POINT-SIZE="10"><I>A relation between goal and other<BR/>elements. </I></FONT>>]
overarch_util__io [shape=box style=filled fillcolor="#85bbf0" label=<<B>util.io</B><BR/><FONT POINT-SIZE="10"><I>Contains I/O related functions. </I></FONT>>]
overarch_data_model__deployment_structure_view [shape=box  label=<<B>deployment-structure-view</B><BR/><FONT POINT-SIZE="10"><I>The deployment structure view is a<BR/>graphical view. It shows the hierarchy<BR/>of the infrastructure and deployments as<BR/>an organigram. </I></FONT>>]
overarch_data_model__output_of [shape=box  label=<<B>output-of</B><BR/><FONT POINT-SIZE="10"><I>A relation between artifacts,<BR/>information or knowledge and processes. </I></FONT>>]
overarch_data_model__process [shape=box  label=<<B>process</B><BR/><FONT POINT-SIZE="10"><I>A process in the process model </I></FONT>>]
overarch_data_model__state [shape=box  label=<<B>state</B><BR/><FONT POINT-SIZE="10"><I>A state in a state machine. </I></FONT>>]
overarch_data_model__context_boundary [shape=box  label=<<B>context-boundary</B><BR/><FONT POINT-SIZE="10"><I>A boundary of a bounded context. </I></FONT>>]
overarch_roles__template_programmer [shape=box style=filled fillcolor="#08427b" label=<<B>Template Programmer</B><BR/><FONT POINT-SIZE="10"><I>Creates templates for artifact<BR/>generation. </I></FONT>>]
overarch_data_model__abstract_node [shape=box  label=<<B>abstract-node</B><BR/><FONT POINT-SIZE="10"><I>A node which may have an abstract field. </I></FONT>>]
overarch_data_model__concept [shape=box  label=<<B>concept</B><BR/><FONT POINT-SIZE="10"><I>A concept in the (ubiquous) language of<BR/>the system. </I></FONT>>]
overarch_data_model__abstract_node_abstract_field [  label=<<B>abstract</B><BR/><FONT POINT-SIZE="10"><I>When true the element is abstract.<BR/>Default is false. </I></FONT>>]
overarch_concepts__use_case [shape=box style=filled fillcolor="#dddddd" label=<<B>Use Case</B><BR/><FONT POINT-SIZE="10"><I>A use case in the use case model. </I></FONT>>]
overarch_data_model__model_element_maturity_field [  label=<<B>maturity</B><BR/><FONT POINT-SIZE="10"><I>Maturity of the element. Values are<BR/>:proposed, :implemented and :deprecated.<BR/>Default is :implemented. </I></FONT>>]
overarch_data_model__has [shape=box  label=<<B>has</B><BR/><FONT POINT-SIZE="10"><I>A composition or association<BR/>relationship between the concepts. </I></FONT>>]
overarch_data_model__associative_relation_to_role_field [  label=<<B>to-role</B><BR/><FONT POINT-SIZE="10"><I>The role of the referred element. </I></FONT>>]
overarch_data_model__policy [shape=box  label=<<B>policy</B><BR/><FONT POINT-SIZE="10"><I>A rule or guideline that governs the<BR/>behavior or actions within the domain. </I></FONT>>]
overarch_adapter_exports__structurizr [shape=box style=filled fillcolor="#85bbf0" label=<<B>adapter.exports.structurizr</B><BR/><FONT POINT-SIZE="10"><I>Contains the implementation of the<BR/>Structurizr export. </I></FONT>>]
overarch_concepts__component [shape=box style=filled fillcolor="#dddddd" label=<<B>Component</B><BR/><FONT POINT-SIZE="10"><I>A (logical) building block of a<BR/>container (e.g. a module or a layer) </I></FONT>>]
overarch_data_model__concept_model_node [shape=box  label=<<B>concept-model-node</B><BR/><FONT POINT-SIZE="10"><I>A node in the concept model. </I></FONT>>]
overarch_domain__view [shape=box style=filled fillcolor="#85bbf0" label=<<B>domain.view</B><BR/><FONT POINT-SIZE="10"><I>Contains the view specification and<BR/>functions. </I></FONT>>]
overarch_use_case__export_model [shape=ellipse style=filled fillcolor=yellow label=<<B>export model</B><BR/><FONT POINT-SIZE="10"><I>Export the model in different formats. </I></FONT>>]
overarch_application__export [shape=box style=filled fillcolor="#85bbf0" label=<<B>application.export</B><BR/><FONT POINT-SIZE="10"><I>Contains the export multimethods to be<BR/>implemented by the concrete export<BR/>adapter implementations. </I></FONT>>]
overarch_data_model__role_in [shape=box  label=<<B>role-in</B><BR/><FONT POINT-SIZE="10"><I>A relation between persons and<BR/>organization units or processes. </I></FONT>>]
overarch_data_model__element_el_field [  label=<<B>el</B><BR/><FONT POINT-SIZE="10"><I>The type of the element. </I></FONT>>]
overarch_data_model__state_machine [shape=box  label=<<B>state-machine</B><BR/><FONT POINT-SIZE="10"><I>A state machine as root element of the<BR/>state machine model. A state machine<BR/>encapsulates a set of states of a system<BR/>and the transitions between these<BR/>states. </I></FONT>>]
overarch_architecture_goal__template_based_artifact_generation [  label=<<B>Template-based Artifact Generation</B><BR/><FONT POINT-SIZE="10"><I>The generation of artifacts from the<BR/>model is fully customizeable via<BR/>templates. </I></FONT>>]
overarch_data_model__model_node [shape=box  label=<<B>model-node</B><BR/><FONT POINT-SIZE="10"><I>An element which is a node in the model. </I></FONT>>]
overarch_architecture__diagram_generator [shape=box style=filled fillcolor="#999999" label=<<B>Diagram Generators</B><BR/><FONT POINT-SIZE="10"><I>generates diagrams from text (e.g.<BR/>Graphviz, PlantUML, Mermaid) </I></FONT>>]
overarch_data_model__role_model_relation [shape=box  label=<<B>role-model-relation</B><BR/><FONT POINT-SIZE="10"><I>A relation in the role model. </I></FONT>>]
overarch_data_model__responsible_for [shape=box  label=<<B>responsible-for</B><BR/><FONT POINT-SIZE="10"><I>A relation between organisational model<BR/>nodes and architecture or deployment<BR/>model elements. </I></FONT>>]
overarch_data_model__glossary_view [shape=box  label=<<B>glossary-view</B><BR/><FONT POINT-SIZE="10"><I>The glossary view is a textual view. It<BR/>shows the main elements and concepts of<BR/>the system under description<BR/>alphabetically sorted. </I></FONT>>]
overarch_architecture_requirement__watch_model_path [  label=<<B>Watch model path</B><BR/><FONT POINT-SIZE="10"><I>The model path should be watched for<BR/>changes and the model should be reloaded<BR/>when changes are detected. </I></FONT>>]
overarch_concepts__aggregate [shape=box style=filled fillcolor="#dddddd" label=<<B>Aggregate</B><BR/><FONT POINT-SIZE="10"><I>A cluster of domain objects that can be<BR/>treated as a single unit for consistency<BR/>and invariants. Part of the solution<BR/>space. </I></FONT>>]
overarch_data_model__element_id_field [  label=<<B>id</B><BR/><FONT POINT-SIZE="10"><I>The identifier of the element. </I></FONT>>]
overarch_data_model__enum [shape=box  label=<<B>enum</B><BR/><FONT POINT-SIZE="10"><I>An enumeration of typed related values<BR/>in the code model. </I></FONT>>]
overarch_data_model__model_relation [shape=box  label=<<B>model-relation</B><BR/><FONT POINT-SIZE="10"><I>An element which is a relation in the<BR/>and describes the relationship of two<BR/>model nodes. </I></FONT>>]
overarch_data_model__deployment_view [shape=box  label=<<B>deployment-view</B><BR/><FONT POINT-SIZE="10"><I>The deployment view is a static<BR/>architectural view. It shows the<BR/>deployment of a system with the<BR/>infrastructure modelled as nodes and the<BR/>containers of the system deployed in<BR/>these nodes. </I></FONT>>]
overarch_data_model__requirement [shape=box  label=<<B>requirement</B><BR/><FONT POINT-SIZE="10"><I>A requirement in the process model </I></FONT>>]
overarch_use_case__create_templates [shape=ellipse style=filled fillcolor=yellow label=<<B>create templates</B><BR/><FONT POINT-SIZE="10"><I>Create templates to generate artifacts<BR/>from model selections. </I></FONT>>]
overarch_concepts__enum [shape=box style=filled fillcolor="#dddddd" label=<<B>Enum</B><BR/><FONT POINT-SIZE="10"><I>An enumeration in the code model. </I></FONT>>]
overarch_data_model__use_case_model_relation [shape=box  label=<<B>use-case-model-relation</B><BR/><FONT POINT-SIZE="10"><I>A relation in the use case model of<BR/>overarch. </I></FONT>>]
overarch_concepts__requirement [shape=box style=filled fillcolor="#dddddd" label=<<B>Requirement</B><BR/><FONT POINT-SIZE="10"><I>A Requirement in the process model, e.g.<BR/>a functional or non-functional<BR/>requirement </I></FONT>>]
overarch_data_model__organization [shape=box  label=<<B>organization</B><BR/><FONT POINT-SIZE="10"><I>An organization (e.g. a company) in the<BR/>organization model. </I></FONT>>]
overarch_data_model__visibility_node_visibility_field [  label=<<B>visibility</B><BR/><FONT POINT-SIZE="10"><I>The visibility of the element. </I></FONT>>]
overarch_concepts__policy [shape=box style=filled fillcolor="#dddddd" label=<<B>Policy</B><BR/><FONT POINT-SIZE="10"><I>A rule or guideline that governs the<BR/>behavior or actions within the domain.<BR/>Part of the solution space. </I></FONT>>]
overarch_application__model_repository [shape=box style=filled fillcolor="#85bbf0" label=<<B>application.model-repository</B><BR/><FONT POINT-SIZE="10"><I>Contains a stateful representation of<BR/>the model and accessor functions to the<BR/>model state. </I></FONT>>]
overarch_concepts__end_state [shape=box style=filled fillcolor="#dddddd" label=<<B>End State</B><BR/><FONT POINT-SIZE="10"><I>A final state of a state machine </I></FONT>>]
overarch_data_model__typed_node [shape=box  label=<<B>typed-node</B><BR/><FONT POINT-SIZE="10"><I>A node which may have a type field. </I></FONT>>]
overarch_data_model__rel [shape=box  label=<<B>rel</B><BR/><FONT POINT-SIZE="10"><I>A generic relation between the concepts. </I></FONT>>]
overarch_architecture_decision__implementation_architecture [  label=<<B>Implementation Architecture</B><BR/><FONT POINT-SIZE="10"><I>Clean Architecture is used to structure<BR/>the implementation </I></FONT>>]
overarch_data_model__boundary_node [shape=box  label=<<B>boundary-node</B><BR/><FONT POINT-SIZE="10"><I>A grouping of elements belonging<BR/>together in a context. </I></FONT>>]
overarch_data_model__use_case_model_node [shape=box  label=<<B>use-case-model-node</B><BR/><FONT POINT-SIZE="10"><I>A node in the use case model of<BR/>overarch. </I></FONT>>]
overarch_data_model__join [shape=box  label=<<B>join</B><BR/><FONT POINT-SIZE="10"><I>A join of transitions in a state<BR/>machine. A join has multiple incoming<BR/>transitions and a single outgoing<BR/>transition. </I></FONT>>]
overarch_data_model__code_model_relation [shape=box  label=<<B>code-model-relation</B><BR/><FONT POINT-SIZE="10"><I>A relation in the code model. </I></FONT>>]
overarch_data_model__associative_relation_to_card_field [  label=<<B>to-card</B><BR/><FONT POINT-SIZE="10"><I>The cardinality of the referred element. </I></FONT>>]
overarch_data_model__regulation [shape=box  label=<<B>regulation</B><BR/><FONT POINT-SIZE="10"><I>A regulation in the process model </I></FONT>>]
overarch_data_model__interface [shape=box  label=<<B>interface</B><BR/><FONT POINT-SIZE="10"><I>An interface in the code model. An<BR/>interface defines related methods. </I></FONT>>]
overarch_data_model__uses [shape=box  label=<<B>uses</B><BR/><FONT POINT-SIZE="10"><I>A use relationship between an actor and<BR/>a use case (or vice versa). </I></FONT>>]
overarch_data_model__fork [shape=box  label=<<B>fork</B><BR/><FONT POINT-SIZE="10"><I>A fork of transitions in a state<BR/>machine. A fork has a single incoming<BR/>transition and multiple outgoing<BR/>transitions. </I></FONT>>]
overarch_data_model__subscribe [shape=box  label=<<B>subscribe</B><BR/><FONT POINT-SIZE="10"><I>Subscription of asynchronous events<BR/>between two elements of the architecture<BR/>(sender should be a broker or topic). </I></FONT>>]
overarch_data_model__state_machine_model_relation [shape=box  label=<<B>state-machine-model-relation</B><BR/><FONT POINT-SIZE="10"><I>A relation in the state machine model. </I></FONT>>]
overarch_data_model__permission_of [shape=box  label=<<B>permission-of</B><BR/><FONT POINT-SIZE="10"><I>A relationship between a permission and<BR/>an architecture node, e.g. a system. </I></FONT>>]
overarch_concepts__package [shape=box style=filled fillcolor="#dddddd" label=<<B>Package</B><BR/><FONT POINT-SIZE="10"><I>A collection of related classes or<BR/>modules. </I></FONT>>]
overarch_concepts__decision [shape=box style=filled fillcolor="#dddddd" label=<<B>Decision</B><BR/><FONT POINT-SIZE="10"><I>A decision in the process model, e.g. an<BR/>architectural decision or a business<BR/>decision </I></FONT>>]
overarch_architecture__overarch [shape=box style=filled fillcolor="#1168bd" label=<<B>Overarch</B><BR/><FONT POINT-SIZE="10"><I>An Open Architecture Knowledge Platform </I></FONT>>]
overarch_concepts__state_machine [shape=box style=filled fillcolor="#dddddd" label=<<B>State Machine</B><BR/><FONT POINT-SIZE="10"><I>A collection of states and transitions </I></FONT>>]
overarch_data_model__context_view [shape=box  label=<<B>context-view</B><BR/><FONT POINT-SIZE="10"><I>The (system) context view is a static<BR/>architectural view. It shows the system<BR/>under description and the interactions<BR/>with it&apos;s environment consisting of<BR/>users and external systems. </I></FONT>>]
overarch_architecture_goal__open_models [  label=<<B>Open Models</B><BR/><FONT POINT-SIZE="10"><I>The knowledge captured in the models<BR/>shall be open and accessible for other<BR/>tools </I></FONT>>]
overarch_data_model__deployment_model_element [shape=box  label=<<B>deployment-model-element</B><BR/><FONT POINT-SIZE="10"><I>An element in the deployment model. </I></FONT>>]
overarch_data_model__composition [shape=box  label=<<B>composition</B><BR/><FONT POINT-SIZE="10"><I>A composition relationship between two<BR/>classes in the code model. </I></FONT>>]
overarch_data_model__model_view [shape=box  label=<<B>model-view</B><BR/><FONT POINT-SIZE="10"><I>The model view is a graphical view. It<BR/>shows all selected elements as a graph. </I></FONT>>]
overarch_data_model__architecture_model_element_external_field [  label=<<B>external</B><BR/><FONT POINT-SIZE="10"><I>When true, the element plays a role in<BR/>the model but it is not in the scope of<BR/>the project. Defaults to false. </I></FONT>>]
overarch_data_model__container_view [shape=box  label=<<B>container-view</B><BR/><FONT POINT-SIZE="10"><I>The container view is a static<BR/>architectural view. It shows the process<BR/>structure of the system under<BR/>description and the interactions between<BR/>these containers and with it&apos;s<BR/>environment consisting of users and<BR/>external systems. </I></FONT>>]
overarch_data_model__constraint_for [shape=box  label=<<B>constraint-for</B><BR/><FONT POINT-SIZE="10"><I>A relation between constraint and other<BR/>elements. </I></FONT>>]
overarch_data_model__role [shape=box  label=<<B>role</B><BR/><FONT POINT-SIZE="10"><I>A human actor or role working with the<BR/>system under description. A person can<BR/>be used in the architecture model and<BR/>the use case model. </I></FONT>>]
overarch_data_model__code_model_node [shape=box  label=<<B>code-model-node</B><BR/><FONT POINT-SIZE="10"><I>A node in the code model. </I></FONT>>]
overarch_data_model__domain_model_element [shape=box  label=<<B>domain-model-element</B><BR/><FONT POINT-SIZE="10"><I>An element in the domain model. </I></FONT>>]
overarch_concepts__class [shape=box style=filled fillcolor="#dddddd" label=<<B>Class</B><BR/><FONT POINT-SIZE="10"><I>A class in the code model. </I></FONT>>]
overarch_architecture__build_pipeline [shape=box style=filled fillcolor="#999999" label=<<B>Build Pipeline</B><BR/><FONT POINT-SIZE="10"><I>Generates and publishes artifacts (e.g.<BR/>build script/pipeline) </I></FONT>>]
overarch_concepts__field [shape=box style=filled fillcolor="#dddddd" label=<<B>Field</B><BR/><FONT POINT-SIZE="10"><I>A field of a class, namespace or schema<BR/>in the code model. </I></FONT>>]
overarch_data_model__role_model_element [shape=box  label=<<B>role-model-element</B><BR/><FONT POINT-SIZE="10"><I>An element of the role model. </I></FONT>>]
