<%= (get protected-areas "ArchitectureDecisions1" "")
%><!-- PA-END(ArchitectureDecisions1) -->

<%
  (when (seq architecture-decisions)
%>
### Decisions
<%=
    (md/node-description-table e :decision architecture-decisions))
%>

<!-- PA-BEGIN(ArchitectureDecisions2) -->
<%= (get protected-areas "ArchitectureDecisions2" "")
