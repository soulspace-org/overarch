<%= (get protected-areas "DeploymentView2" "")
%><!-- PA-END(DeploymentView2) -->

## Crosscutting Concepts
<!-- PA-BEGIN(CrosscuttingConcepts) -->
<%= (get protected-areas "CrosscuttingConcepts" "")
