  ;; Domain
  ;;
  {:el :concept
   :id :overarch.concepts/domain
   :name "Domain"
   :desc "A specific area of knowledge, activity or subject matter. Part of the problem space."}
  {:el :concept
   :id :overarch.concepts/bounded-context
   :name "Bounded Context"
   :desc "A boundary within which a particular domain model is valid and consistent. Part of the solution space."}
  {:el :concept
   :id :overarch.concepts/aggregate
   :name "Aggregate"
   :desc "A cluster of domain objects that can be treated as a single unit for consistency and invariants. Part of the solution space."}
  {:el :concept
   :id :overarch.concepts/entity
   :name "Entity"
   :desc "An object that is defined by its identity, rather than its attributes. Part of the solution space."}
  {:el :concept
   :id :overarch.concepts/value-object
   :name "Value Object"
   :desc "An object that is defined by its attributes, rather than its identity. Part of the solution space."}
  {:el :concept
   :id :overarch.concepts/domain-event
   :name "Domain Event"
   :desc "An event that represents a significant change in the state of the domain. Part of the solution space."}
  {:el :concept
   :id :overarch.concepts/policy
   :name "Policy"
   :desc "A rule or guideline that governs the behavior or actions within the domain. Part of the solution space."}
  {:el :concept
   :id :overarch.concepts/command
   :name "Command"
   :desc "An instruction to perform a specific action or operation within the domain. Part of the solution space."}

